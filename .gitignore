# ---------------------------------------------------------------------------
# VS Code
# ---------------------------------------------------------------------------
# Ignore the folder by default, but allow a curated set of shared project
# settings to be committed. This keeps per-user state (history, workspace
# caches) out of git while letting the team share launch configs, tasks,
# recommended extensions, and workspace settings.

.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# Local History extension
.history/

# Built VS Code extensions
*.vsix

# ---------------------------------------------------------------------------
# Project-specific
# ---------------------------------------------------------------------------

# Interactive Brokers statement exports may contain personal financial data.
# Keep a dedicated folder out of version control by default; add specific
# fixture files back explicitly if you need them checked in.
data/
statements/
*.csv
*.xlsx
*.xls

# SQLite databases produced by local runs
*.sqlite
*.sqlite3
*.db

# Secrets / credentials
secrets/
*.pem
*.key
